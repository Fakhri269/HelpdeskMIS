generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
}

model UnitKerja {
  id        String         @id @default(cuid())
  name      String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  subUnits  SubUnitKerja[]
  tickets   Ticket[]       @relation("TicketUnitKerja")
  users     User[]
}

model SubUnitKerja {
  id          String    @id @default(cuid())
  name        String
  unitKerjaId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  unitKerja   UnitKerja @relation(fields: [unitKerjaId], references: [id], onDelete: Cascade)
  tickets     Ticket[]  @relation("TicketSubUnitKerja")
  users       User[]

  @@unique([name, unitKerjaId])
}

model User {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  password        String
  roleId          String
  unitKerjaId     String?
  subUnitKerjaId  String?
  position        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  assignedTickets Ticket[]        @relation("TicketAssignee")
  createdTickets  Ticket[]        @relation("TicketCreator")
  comments        TicketComment[]
  role            Role            @relation(fields: [roleId], references: [id])
  subUnitKerja    SubUnitKerja?   @relation(fields: [subUnitKerjaId], references: [id])
  unitKerja       UnitKerja?      @relation(fields: [unitKerjaId], references: [id])
}

model MasterSLA {
  id        String   @id @default(cuid())
  priority  String   @unique
  hours     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MasterKategori {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Ticket {
  id             String          @id @default(cuid())
  ticketNumber   String          @unique
  title          String
  description    String
  status         String          @default("Open")
  priority       String
  category       String
  creatorId      String
  assigneeId     String?
  unitKerjaId    String
  subUnitKerjaId String?
  slaDeadline    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  assignee       User?           @relation("TicketAssignee", fields: [assigneeId], references: [id])
  creator        User            @relation("TicketCreator", fields: [creatorId], references: [id])
  subUnitKerja   SubUnitKerja?   @relation("TicketSubUnitKerja", fields: [subUnitKerjaId], references: [id])
  unitKerja      UnitKerja       @relation("TicketUnitKerja", fields: [unitKerjaId], references: [id])
  comments       TicketComment[]
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  content   String
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  tags      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
