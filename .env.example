# Supabase PostgreSQL Connection Pooler (for the app)
# Port 6543 and parameter ?pgbouncer=true
DATABASE_URL="postgres://[db-user]:[db-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase PostgreSQL Direct Connection (for migrations)
# Port 5432
DIRECT_URL="postgres://[db-user]:[db-password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# JWT Secret for Auth (if needed)
NEXTAUTH_SECRET="your-super-secret-jwt-token"
NEXTAUTH_URL="http://localhost:3000"
